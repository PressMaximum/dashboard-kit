# https://editorconfig.org
# Matches Blocksify Free + WordPress Coding Standards
# https://make.wordpress.org/core/handbook/coding-standards/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab

[*.{md,yml,yaml,json}]
indent_style = space
indent_size = 2

[*.{css,scss}]
indent_style = tab
